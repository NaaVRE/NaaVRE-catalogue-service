meta {
  name: test-user-3 list 2
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/workflow-cells/?shared_with_me=true&all_versions=false
  body: none
  auth: bearer
}

params:query {
  shared_with_me: true
  all_versions: false
}

auth:bearer {
  token: {{notOurJWT}}
}

tests {
  test("Status code is 200", function () {
      expect(res.getStatus()).to.equal(200);
  });
  test("JSON response is valid", function () {
      var jsonData = res.getBody();
      expect(jsonData.count).to.deep.eq(1);
  });
}
